---
import { getCollection } from 'astro:content';
import { iconSrc } from '../utils/iconUtils';

const components = await getCollection('component');
const icons = components
  .filter((component) => !component.data.hidden && component.data.type !== 'starter')
  .map((component) => ({ icon: component.data.icon, url: component.data.url }));
---

<div class="icons">
  <ul>
    {
      icons.map(({ icon, url }) => (
        <li>
          <img alt="component icon" src={iconSrc(icon, url)} width={24} height={24} />
        </li>
      ))
    }
  </ul>
  <div>
    <ul>
      {
        icons.map(({ icon, url }) => (
          <li>
            <img alt="component icon" src={iconSrc(icon, url)} width={24} height={24} />
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style lang="scss">
  @keyframes component-icon-scroll {
    0% {
      translate: 0 0 10px;
    }
    100% {
      translate: calc((100% + 16px) * -1) 0 10px;
    }
  }

  .icons {
    position: relative;
    display: flex;
    width: min(600px, 90vw);
    user-select: none;
    pointer-events: none;

    mask-image: linear-gradient(to right, transparent, white 20%, white 80%, transparent);

    > ul,
    > div > ul {
      display: flex;
      gap: 16px;
      margin-right: 16px;

      animation: component-icon-scroll 30s linear infinite;

      > li {
        @media (prefers-reduced-motion: reduce) {
          animation: none;
        }
      }
    }

    > div {
      position: absolute;
      translate: 100% 0;
    }
  }
</style>
