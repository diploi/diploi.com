---
import type { HTMLAttributes } from 'astro/types';
import { extractRepositoryOwnerAndRepo } from './utils';

type Props = {
  name: string;
  url: string;
  size?: number;
} & HTMLAttributes<'img'>;

const { name, url, size = 28, ...other } = Astro.props;

const { owner, repo } = extractRepositoryOwnerAndRepo(url);

const imageSrc = `https://diploi.b-cdn.net/component/${owner}/${repo}/icon.svg?ref=main`;
---

<img alt={`${name} icon`} src={imageSrc} class="icon" width={size} height={size} {...other} />
