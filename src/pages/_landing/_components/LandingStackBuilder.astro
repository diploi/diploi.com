---
import { createStackBackgroundUri } from '../../features/_components/featuresUtils';
import ImportHeroCta from '../../import/_components/ImportHeroCta.astro';

const background = createStackBackgroundUri({
  size: 16,
  primary: 'rgba(255, 255, 255, 0.05)',
  secondary: 'rgba(255, 255, 255, 0.05)',
  chance: 0.1,
});
---

<section>
  <div class="background" inert aria-hidden style={{ '--background': background }}></div>
  <h2>Already Working on Something?</h2>
  <p>Pick any repository and we'll make it run.</p>
  <ImportHeroCta />
</section>

<style lang="scss">
  section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin: 0 auto;
    width: 100%;
    max-width: var(--max-width-page-section);

    > h2 {
      margin: 0;
    }

    > p {
      text-align: center;
    }
  }

  @keyframes scroll {
    0% {
      translate: 0 0 10px;
    }
    100% {
      translate: calc((100% + 16px) * -1) 0 10px;
    }
  }

  .icons {
    position: relative;
    display: flex;
    width: min(600px, 90vw);
    user-select: none;
    pointer-events: none;

    mask-image: linear-gradient(to right, transparent, white 20%, white 80%, transparent);

    > ul,
    > div > ul {
      display: flex;
      gap: 16px;
      margin-right: 16px;

      animation: scroll 30s linear infinite;

      > li {
        @media (prefers-reduced-motion: reduce) {
          animation: none;
        }
      }
    }

    > div {
      position: absolute;
      translate: 100% 0;
    }
  }

  .background {
    position: absolute;
    left: 0;
    margin-top: -120px;
    width: 100%;
    height: 500px;
    background-image: var(--background);
    background-size: 896px;
    overflow: hidden;
    z-index: -1;

    mask-image: linear-gradient(to bottom, transparent, white 50%, transparent);
  }
</style>
