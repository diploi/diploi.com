---
import { Font } from 'astro:assets';
import { InfoIcon, WarningCircleIcon } from '@phosphor-icons/react';
import icon from '../../images/logo-icon.svg';
import { createStackBackgroundUri } from '../features/_components/featuresUtils';

const background = createStackBackgroundUri({
  size: 16,
  primary: 'rgba(255, 255, 255, 0.1)',
  secondary: 'rgba(255, 255, 255, 0.1)',
  chance: 0.4,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Diploi - Error 500</title>

    <link rel="icon" type="image/svg" href={icon.src} />

    {/* Fonts */}
    <Font cssVariable="--font-header" preload />
    <Font cssVariable="--font-body" preload />
  </head>
  <body>
    <main style={{ '--background': background }}>
      <div class="error">
        <WarningCircleIcon weight="bold" />
        <span>Error</span>
      </div>
      <h1 id="title">500</h1>
      ::CLOUDFLARE_ERROR_500S_BOX::
      <p><InfoIcon /> Check your Diploi component</p>
    </main>

    <script>
      const error = document.querySelector('.cf-error-details')?.className.match(/cf-error-(\d+)/)?.[1] || '500';
      document.title = `Diploi - Error ${error}`;
      const title = document.getElementById('title');
      if (title) title.innerText = error;
    </script>

    <style lang="scss">
      main {
        position: absolute;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background-color: black;
        font-family: var(--font-body);
        color: white;

        &::before {
          position: absolute;
          content: '';
          display: block;
          width: 120%;
          height: 180%;
          mask-image: radial-gradient(circle, transparent 10%, white);
          background-image: var(--background);
          background-size: 896px;
          transform: rotate(8deg);
          z-index: 0;
        }

        * {
          z-index: 1;
        }

        .error {
          display: flex;
          justify-content: center;
          align-items: center;
          gap: 3px;
          padding: 0 10px 0 4px;
          background-color: #d05353;
          border-radius: 32px;
          color: black;

          span {
            font-weight: bold;
          }
        }

        > h1 {
          margin: 0;
          font-size: 128px;
          font-family: var(--font-header);
        }

        p {
          display: flex;
          justify-content: center;
          align-items: center;
          gap: 4px;
          margin-top: 0;
          opacity: 0.7;
        }
      }

      :global(.cf-error-details) {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        > :global(h1) {
          margin: 0;
          text-align: center;
        }

        > :global(p) {
          max-width: 65ch;
          text-align: center;
          opacity: 0.7;
        }

        > :global(ul) {
          display: none;
        }
      }
    </style>
  </body>
</html>
